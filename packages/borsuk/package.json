{
  "name": "borsuk",
  "version": "0.1.0",
  "description": "Native TypeScript API for BORSUK, backed by Rust through N-API",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://riomus.github.io/borsuk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riomus/borsuk.git",
    "directory": "packages/borsuk"
  },
  "bugs": {
    "url": "https://github.com/riomus/borsuk/issues"
  },
  "keywords": [
    "ann",
    "similarity-search",
    "vector-search",
    "s3",
    "parquet",
    "rust",
    "napi"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "dist/examples",
    "index.cjs",
    "*.node",
    "native.d.ts",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --manifest-path ../../crates/borsuk-node/Cargo.toml --output-dir . --js index.cjs --dts native.d.ts",
    "build": "tsc -p tsconfig.json",
    "example:local": "npm run build && node dist/examples/local-index.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
