{
  "name": "borsuk",
  "version": "0.1.0",
  "description": "Native TypeScript API for BORSUK, backed by Rust through N-API",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "index.cjs",
    "*.node",
    "native.d.ts",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --manifest-path ../../crates/borsuk-node/Cargo.toml --output-dir . --js index.cjs --dts native.d.ts",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
