{
  "name": "borsuk",
  "version": "0.1.0",
  "description": "Native TypeScript API for BORSUK, backed by Rust through N-API",
  "type": "module",
  "license": "BUSL-1.1",
  "homepage": "http://causality.pl/borsuk/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CausalityHQ/borsuk.git",
    "directory": "packages/borsuk"
  },
  "bugs": {
    "url": "https://github.com/CausalityHQ/borsuk/issues"
  },
  "keywords": [
    "ann",
    "similarity-search",
    "vector-search",
    "s3",
    "parquet",
    "rust",
    "napi"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./compat/pinecone": {
      "types": "./dist/src/compat/pinecone.d.ts",
      "import": "./dist/src/compat/pinecone.js"
    },
    "./compat/s3vectors": {
      "types": "./dist/src/compat/s3vectors.d.ts",
      "import": "./dist/src/compat/s3vectors.js"
    },
    "./compat/turbopuffer": {
      "types": "./dist/src/compat/turbopuffer.d.ts",
      "import": "./dist/src/compat/turbopuffer.js"
    }
  },
  "engines": {
    "node": ">=22 <27"
  },
  "files": [
    "dist/src",
    "dist/examples",
    "index.cjs",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --manifest-path ../../crates/borsuk-node/Cargo.toml --output-dir . --js index.cjs --dts native.d.ts",
    "build": "tsc -p tsconfig.json",
    "example:local": "npm run build && node dist/examples/local-index.js",
    "example:s3": "npm run build && node dist/examples/s3-index.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0"
  }
}
